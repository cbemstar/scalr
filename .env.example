# PostHog — client analytics (instrumentation-client.ts)
# Project API key: PostHog → Project settings → Project API key
# Host: US https://us.i.posthog.com | EU https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set to 1 on Vercel temporarily to log PostHog debug output in the browser console
# NEXT_PUBLIC_POSTHOG_DEBUG=1

# Airtable — project brief form (schema + field types: src/lib/airtable-inquiry.ts)
# Create a Personal Access Token: https://airtable.com/create/tokens
# Scopes: data.records:write, data.records:read, schema.bases:read
# For configuring the Status (Kanban) field options: also add schema.bases:write, then run:
#   npm run airtable:pipeline
# In Airtable: grant this integration access to your base (profile → Integrations).

AIRTABLE_PAT=
# Base "Untitled Base" — table "Inquiries" (create in your account if different)
AIRTABLE_BASE_ID=appBhlcJvtiCaRxPT
# Optional — defaults to "Inquiries" if unset
AIRTABLE_TABLE_NAME=Inquiries

# Cloudflare Turnstile — project brief spam protection (optional for local dev)
# Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# Always-passing test keys (dev only): site key 1x00000000000000000000AA, secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
