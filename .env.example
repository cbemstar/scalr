# Airtable — project brief form (see src/lib/airtable-inquiry.ts for table fields)
# Create a Personal Access Token: https://airtable.com/create/tokens
# Scopes: data.records:write, data.records:read, schema.bases:read
# In Airtable: grant this integration access to your base (profile → Integrations).

AIRTABLE_PAT=
# Base "Untitled Base" — table "Inquiries" (create in your account if different)
AIRTABLE_BASE_ID=appBhlcJvtiCaRxPT
# Optional — defaults to "Inquiries" if unset
AIRTABLE_TABLE_NAME=Inquiries
